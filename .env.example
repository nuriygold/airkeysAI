# AirKeys AI — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic Claude API key (required for AI completions and suggestions)
ANTHROPIC_API_KEY=sk-ant-...

# n8n webhook base URL (optional — enables slash command workflow automation)
# Example: http://localhost:5678 or https://your-n8n-instance.com
N8N_WEBHOOK_URL=https://your-n8n-instance.com

# CREAO API key (optional — enables CREAO agent app commands)
CREAO_API_KEY=

# Server config (optional — defaults shown)
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
